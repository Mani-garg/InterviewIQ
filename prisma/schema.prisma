generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Resume {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  mimeType      String
  storageBucket String
  storagePath   String
  extractedText String   @db.Text
  sections      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Interview {
  id            String   @id @default(cuid())
  userId        String
  company       String
  role          String
  difficulty    String
  questionCount Int
  questions     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Resume {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  mimeType      String
  storageBucket String
  storagePath   String
  extractedText String   @db.Text
  sections      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Interview {
  id            String @id @default(cuid())
  userId        String
  company       String
  role          String
  difficulty    String
  questionCount Int
  questions     Json

  status       String    @default("not_started")
  overallScore Int?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers Answer[]

  @@index([userId])
  @@index([createdAt])
}

model Answer {
  id          String @id @default(cuid())
  interviewId String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  questionIndex Int
  question      String
  answerText    String @db.Text

  score    Int?
  feedback String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([interviewId, questionIndex])
  @@index([interviewId])
}
